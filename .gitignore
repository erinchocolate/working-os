# ── 私有内容：真实填充的内容只存本地；仅上传目录结构（.gitkeep 占位）──

# projects/：忽略所有真实项目（如 Marvin），仅保留目录结构
projects/*
!projects/.gitkeep

# reviews/：忽略真实复盘与候选池，仅保留目录结构
reviews/*
!reviews/daily/
reviews/daily/*
!reviews/daily/.gitkeep
!reviews/weekly/
reviews/weekly/*
!reviews/weekly/.gitkeep
!reviews/system/
reviews/system/*
!reviews/system/.gitkeep

# inbox/worklog/reminders：真实工作材料仅本地保存
inbox/*
!inbox/.gitkeep
!inbox/_processed/
inbox/_processed/*
!inbox/_processed/.gitkeep
!inbox/_needs-review/
inbox/_needs-review/*
!inbox/_needs-review/.gitkeep
worklog/*
!worklog/.gitkeep
reminders/*
!reminders/.gitkeep
!reminders/daily/
reminders/daily/*
!reminders/daily/.gitkeep
!reminders/weekly/
reminders/weekly/*
!reminders/weekly/.gitkeep
!reminders/system/
reminders/system/*
!reminders/system/.gitkeep
!reminders/inbox/
reminders/inbox/*
!reminders/inbox/.gitkeep

# scripts/：本机自动化执行器仅本地保存；GitHub 保留规则与 runbook，不保留机器绑定脚本
scripts/*
!scripts/.gitkeep

# style/：忽略真实画像与样本，仅保留目录结构
style/*
!style/english-samples/
!style/sharing-samples/
style/english-samples/*
!style/english-samples/.gitkeep
style/sharing-samples/*
!style/sharing-samples/.gitkeep

# learning/：忽略真实内容，仅保留目录结构
learning/*
!learning/.gitkeep

# 杂项
*.local.md
.DS_Store
idea.md
